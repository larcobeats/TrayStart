<Window x:Class="TrayStart.Views.RunningAppsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add a running window"
        Width="480" Height="400"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6F8"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Pick a window — its program will be added to the watch list."
                   Foreground="#5A606B" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <Border Grid.Row="1" Background="White" CornerRadius="6" BorderBrush="#E0E3E8" BorderThickness="1">
            <ListView x:Name="WindowList" BorderThickness="0" Background="Transparent"
                      MouseDoubleClick="WindowList_MouseDoubleClick"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="260" Header="Window" DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Width="160" Header="Process" DisplayMemberBinding="{Binding ExeName}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Refresh" Click="Refresh_Click" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="Add" Click="Add_Click" Padding="16,6" Margin="0,0,8,0" IsDefault="True"/>
            <Button Content="Cancel" IsCancel="True" Padding="12,6"/>
        </StackPanel>
    </Grid>
</Window>
