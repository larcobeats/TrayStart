<Window x:Class="TrayStart.Views.RunningAppsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add a running window"
        Width="500" Height="420"
        MinWidth="420" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Icon="/Assets/TrayStart.ico"
        UseLayoutRounding="True"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Pick a window — its program will be added to the watch list."
                   Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="10"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="1" Opacity="0.06"/>
            </Border.Effect>
            <ListView x:Name="WindowList" BorderThickness="0" Background="Transparent" Margin="6,4"
                      MouseDoubleClick="WindowList_MouseDoubleClick"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="260" Header="Window" DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Width="160" Header="Process" DisplayMemberBinding="{Binding ExeName}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Refresh" Click="Refresh_Click" Margin="0,0,8,0"/>
            <Button Content="Add" Click="Add_Click" Style="{StaticResource AccentButton}"
                    Padding="18,7" Margin="0,0,8,0" IsDefault="True"/>
            <Button Content="Cancel" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
