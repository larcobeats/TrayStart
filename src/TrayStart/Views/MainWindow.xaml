<Window x:Class="TrayStart.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayStart"
        Width="560" Height="520"
        MinWidth="480" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="TrayStart" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding VersionText}" FontSize="12" Foreground="#8A8F98"
                           VerticalAlignment="Bottom" Margin="8,0,0,4"/>
            </StackPanel>
            <TextBlock Text="Programs in this list are automatically minimized to the tray when they start. If an app already has its own tray icon, TrayStart won't add a duplicate — restore it from the app's own icon."
                       Foreground="#5A606B" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Watched apps list -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" BorderBrush="#E0E3E8" BorderThickness="1">
            <ListView ItemsSource="{Binding WatchedApps}"
                      SelectedItem="{Binding SelectedApp}"
                      BorderThickness="0"
                      Background="Transparent"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="60" Header="On">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="190" Header="Application"
                                        DisplayMemberBinding="{Binding DisplayName}"/>
                        <GridViewColumn Width="150" Header="Process"
                                        DisplayMemberBinding="{Binding ExeName}"/>
                        <GridViewColumn Width="110" Header="Own tray icon">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding HasOwnTray, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              ToolTip="This app already has its own tray icon, so TrayStart hides the window without adding a duplicate icon. Use the app's own icon to bring it back."/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- List actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Add program…" Command="{Binding AddFromFileCommand}"
                    Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="Add running window…" Command="{Binding AddFromRunningCommand}"
                    Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="Remove" Command="{Binding RemoveCommand}" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="Minimize to tray now" Command="{Binding MinimizeNowCommand}" Padding="12,6"/>
        </StackPanel>

        <!-- Options -->
        <CheckBox Grid.Row="3" Content="Start TrayStart when Windows starts"
                  IsChecked="{Binding StartWithWindows}" Margin="0,16,0,0"/>

        <!-- Updates -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding UpdateStatus}" Foreground="#5A606B"
                       VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0"/>
            <Button Grid.Column="1" Content="Check for updates"
                    Command="{Binding CheckForUpdatesCommand}" Padding="12,6"/>
        </Grid>
    </Grid>
</Window>
