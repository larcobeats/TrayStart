<Window x:Class="TrayStart.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayStart"
        Width="620" Height="560"
        MinWidth="540" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Icon="/Assets/TrayStart.ico"
        UseLayoutRounding="True">
    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Image Source="/Assets/TrayStart.png" Width="40" Height="40"
                   RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="TrayStart" FontSize="20" FontWeight="SemiBold"/>
                    <Border Background="#EFF4FE" CornerRadius="10" Padding="8,2"
                            Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding VersionText}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Programs in this list start minimized to the tray. Apps with their own tray icon won't get a duplicate — restore those from the app's icon."
                           FontSize="12" Foreground="{StaticResource SubtleTextBrush}"
                           Margin="0,3,0,0" TextWrapping="Wrap" MaxWidth="440"/>
            </StackPanel>
        </StackPanel>

        <!-- Watched apps card -->
        <Grid Grid.Row="1">
            <Border Background="{StaticResource CardBrush}" CornerRadius="10"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="1" Opacity="0.06"/>
                </Border.Effect>
                <ListView ItemsSource="{Binding WatchedApps}"
                          SelectedItem="{Binding SelectedApp}"
                          BorderThickness="0"
                          Background="Transparent"
                          Margin="6,4"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="52" Header="On">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="200" Header="Application"
                                            DisplayMemberBinding="{Binding DisplayName}"/>
                            <GridViewColumn Width="170" Header="Process"
                                            DisplayMemberBinding="{Binding ExeName}"/>
                            <GridViewColumn Width="105" Header="Own tray icon">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding HasOwnTray, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  ToolTip="This app already has its own tray icon, so TrayStart hides the window without adding a duplicate icon. Use the app's own icon to bring it back."/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
            <TextBlock Text="No programs yet — click “Add program…” to get started."
                       Foreground="{StaticResource FaintTextBrush}" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WatchedApps.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- List actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Add program…" Command="{Binding AddFromFileCommand}"
                    Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
            <Button Content="Add running window…" Command="{Binding AddFromRunningCommand}" Margin="0,0,8,0"/>
            <Button Content="Remove" Command="{Binding RemoveCommand}" Margin="0,0,8,0"/>
            <Button Content="Minimize to tray now" Command="{Binding MinimizeNowCommand}"/>
        </StackPanel>

        <!-- Options + updates card -->
        <Border Grid.Row="3" Background="{StaticResource CardBrush}" CornerRadius="10"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                Padding="16,12" Margin="0,16,0,0">
            <StackPanel>
                <CheckBox Content="Start TrayStart when Windows starts"
                          IsChecked="{Binding StartWithWindows}"/>
                <Border Height="1" Background="#EEF0F3" Margin="0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding UpdateStatus}"
                               Foreground="{StaticResource SubtleTextBrush}" FontSize="12"
                               VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0"/>
                    <Button Grid.Column="1" Content="Check for updates"
                            Command="{Binding CheckForUpdatesCommand}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
