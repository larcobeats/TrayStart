<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <StartupObject>TrayStart.Program</StartupObject>
    <ApplicationIcon>Assets\TrayStart.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Version>0.3.0</Version>
    <Authors>larcobeats</Authors>
    <Product>TrayStart</Product>
    <Description>Automatically minimize any application to the system tray when it starts.</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- WinForms is referenced only for NotifyIcon; keep its namespace out of the global usings
         so it doesn't collide with WPF types (Application, MessageBox, ...). -->
    <Using Remove="System.Windows.Forms" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageReference Include="Velopack" Version="1.2.0" />
  </ItemGroup>

</Project>
